# claude-memory — optional environment overrides. Copy to .env or export in your shell.
# Every config key is mirrored as CLAUDE_MEMORY_<SECTION>_<KEY> (see ~/.claude-memory/config.toml).

# --- Core ---------------------------------------------------------------------------------
# CLAUDE_MEMORY_DATA_DIR=~/.claude-memory        # where the store + config + logs live
# CLAUDE_MEMORY_BACKEND=sqlite_fts               # sqlite_fts (default) | qdrant | pgvector

# --- Retrieval tuning (the dials you actually turn) ---------------------------------------
# CLAUDE_MEMORY_RETRIEVAL_K=6
# CLAUDE_MEMORY_RETRIEVAL_THRESHOLD=0.35         # raise to inject less, lower to inject more
# CLAUDE_MEMORY_LOGGING_RETRIEVAL_LOG=true       # (query, ids, scores, tier) -> retrieval.jsonl

# --- Vector path (backend = qdrant) -------------------------------------------------------
# QDRANT_URL=http://localhost:6333
# CLAUDE_MEMORY_QDRANT_COLLECTION=claude_memory
# CLAUDE_MEMORY_QDRANT_HNSW_M=16
# CLAUDE_MEMORY_QDRANT_HNSW_EF=128
# CLAUDE_MEMORY_QDRANT_QUANTIZATION=false

# --- Embedding provider (pin one, or leave unset for auto-detection on `setup`) -----------
# CLAUDE_MEMORY_EMBEDDING_PROVIDER=fastembed     # ollama | fastembed | tei | voyage | openai
# CLAUDE_MEMORY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# OLLAMA_HOST=http://localhost:11434
# TEI_URL=http://localhost:8080
# VOYAGE_API_KEY=...                             # hosted: network + cost, leaves your box
# OPENAI_API_KEY=...                             # hosted: network + cost, leaves your box

# --- Claude Code integration --------------------------------------------------------------
# CLAUDE_CONFIG_DIR=~/.claude                    # where `init`/`setup` write hooks + MCP config
