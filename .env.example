# sup-mem — optional environment overrides. Copy to .env or export in your shell.
# Every config key is mirrored as SUP_MEM_<SECTION>_<KEY> (see ~/.sup-mem/config.toml).

# --- Core ---------------------------------------------------------------------------------
# SUP_MEM_DATA_DIR=~/.sup-mem        # where the store + config + logs live
# SUP_MEM_BACKEND=sqlite_fts               # sqlite_fts (default) | qdrant | pgvector

# --- Retrieval tuning (the dials you actually turn) ---------------------------------------
# SUP_MEM_RETRIEVAL_K=6
# SUP_MEM_RETRIEVAL_THRESHOLD=0.35         # raise to inject less, lower to inject more
# SUP_MEM_LOGGING_RETRIEVAL_LOG=true       # (query, ids, scores, tier) -> retrieval.jsonl

# --- Vector path (backend = qdrant) -------------------------------------------------------
# QDRANT_URL=http://localhost:6333
# SUP_MEM_QDRANT_COLLECTION=sup_mem
# SUP_MEM_QDRANT_HNSW_M=16
# SUP_MEM_QDRANT_HNSW_EF=128
# SUP_MEM_QDRANT_QUANTIZATION=false

# --- Embedding provider (pin one, or leave unset for auto-detection on `setup`) -----------
# SUP_MEM_EMBEDDING_PROVIDER=fastembed     # ollama | fastembed | tei | voyage | openai
# SUP_MEM_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# OLLAMA_HOST=http://localhost:11434
# TEI_URL=http://localhost:8080
# VOYAGE_API_KEY=...                             # hosted: network + cost, leaves your box
# OPENAI_API_KEY=...                             # hosted: network + cost, leaves your box

# --- Claude Code integration --------------------------------------------------------------
# CLAUDE_CONFIG_DIR=~/.claude                    # where `init`/`setup` write hooks + MCP config
